# ════════════════════════════════════════════════════════════════
# 🐾 FurBot — .env configuration
# ════════════════════════════════════════════════════════════════
# ⚠️ DO NOT SHARE THIS FILE (contains secrets)
# ════════════════════════════════════════════════════════════════

BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_server_id_here

JSONBIN_KEY=your_jsonbin_key_here
# JSONBIN_BIN_furbot=your_bin_id_here

# RAILWAY_PUBLIC_DOMAIN=yourapp.up.railway.app


# ════════════════════════════════════════════════════════════════
# 📖 HOW TO GET THESE VALUES
# ════════════════════════════════════════════════════════════════


# ── 🔧 Discord Bot Setup ────────────────────────────────────────

# 🌐 https://discord.com/developers/applications
# ➤ Create or select your application

# 🤖 BOT_TOKEN:
# ➤ Go to "Bot" tab
# ➤ Click "Reset Token"
# ➤ Paste it above

# 🆔 CLIENT_ID:
# ➤ Go to "General Information"
# ➤ Copy "Application ID"

# 📌 GUILD_ID (your server):
# ➤ Enable Developer Mode:
#    Settings → Advanced → Developer Mode
# ➤ Right-click your server → Copy Server ID


# ── 💾 JSONBin (Optional but recommended) ───────────────────────

# Used for saving:
# ➤ Channels
# ➤ Roles
# ➤ /setup config

# ❌ If you DO NOT use JSONBin:
# ➤ /setup will NOT save after restart
# ➤ You must use manual IDs in settings.js

# 🌐 https://jsonbin.io
# ➤ Sign up → API Keys → Create Access Key
# ➤ Paste into JSONBIN_KEY above

# 📦 FIRST RUN ONLY:
# ➤ Bot prints a BIN ID in console
# ➤ Paste it into JSONBIN_BIN_furbot to enable saving


# ── 🚆 Railway (Optional) ───────────────────────────────────────

# Only needed if deploying on Railway

# ⚡ Usually auto-set by Railway (DO NOT change manually)
# RAILWAY_PUBLIC_DOMAIN=yourapp.up.railway.app

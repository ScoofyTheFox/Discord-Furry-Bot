# ================================================================
#  🐾 PAWBOT — .env
#  Fill these in to run the bot on your desktop for testing.
#
#  HOW TO GET THESE VALUES:
#  1. Go to discord.com/developers/applications
#  2. Create a New Application → go to the Bot tab
#  3. Reset Token → copy BOT_TOKEN
#  4. General Information page → copy APPLICATION ID as CLIENT_ID
#  5. Right click your server in Discord → Copy Server ID → GUILD_ID
#     (Need Developer Mode? Settings → Advanced → Developer Mode)
# ================================================================

BOT_TOKEN=paste_your_bot_token_here
CLIENT_ID=paste_your_application_id_here
GUILD_ID=paste_your_server_id_here

# ================================================================
#  JSONBin — free persistent storage for channels/roles/settings
#
#  HOW TO GET YOUR KEY:
#  1. Sign up free at jsonbin.io (no credit card)
#  2. Click "API Keys" in the top menu
#  3. Create Access Key → copy it below
#
#  OPTIONAL — leave blank to run without persistence
#  (channels/roles set via /setup commands will reset on restart)
# ================================================================

JSONBIN_KEY=paste_your_jsonbin_key_here

# After first run, the bot will print a bin ID in the console.
# Paste it here so data persists across restarts:
# JSONBIN_BIN_pawbot=

# ================================================================
#  Railway only — not needed for desktop testing
# ================================================================
# RAILWAY_PUBLIC_DOMAIN=yourapp.up.railway.app
